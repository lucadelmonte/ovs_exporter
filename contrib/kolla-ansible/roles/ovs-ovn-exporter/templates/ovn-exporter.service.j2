[Unit]
Description={{ ovn_exporter_description }}
After=network.target

[Service]
User={{ ovn_exporter_user }}
Group={{ ovn_exporter_group }}
EnvironmentFile=-/etc/sysconfig/{{ ovn_exporter_service_name }}
EnvironmentFile=-/etc/default/{{ ovn_exporter_service_name }}
ExecStart={{ exporter_install_dir }}/ovn-exporter $OPTIONS
Restart=on-failure

[Install]
WantedBy=multi-user.target
